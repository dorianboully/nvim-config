# ---------- greek (ex greek.json) ----------
# All automatic: `;` never appears in a real typst identifier, so there's no
# false-positive risk even without the math context guard — added anyway for
# consistency and because that's genuinely where these are used.

context math(context)
snippet ;a "alpha" Ai
alpha
endsnippet

context math(context)
snippet ;b "beta" Ai
beta
endsnippet

