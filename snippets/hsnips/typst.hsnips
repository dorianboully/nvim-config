# Typst snippets for HyperSnips (VSCode) — curated port of snippets/typst/*.json
# + snippets/typst/math.lua (2026-07-03). Nvim/LuaSnip keeps reading the originals.
#
# Flags: w = word boundary (LuaSnip wordTrig=true parity)
#        i = in-word, matches as a word suffix (LuaSnip wordTrig=false parity)
#        A = automatic expansion (no Tab). Only used where `context math(context)`
#            gates it to real typst math mode (markup.math.typst, verified against
#            tinymist's compiled grammar) or where the trigger is `;`-prefixed and
#            therefore can never collide with a real identifier.

global
function math(context) {
  return context.scopes.some((s) => s.startsWith("markup.math.typst"));
}
endglobal

# ---------- suffix operators (ex math.lua) ----------

# jj/kk replace sp/sb (vim reference: j = down = subscript, k = up = superscript)
context math(context)
snippet kk "superscript" Ai
^($1)
endsnippet

context math(context)
snippet jj "subscript" Ai
_($1)
endsnippet

snippet sbp "subscript and superscript" i
_($1)^($2) $0
endsnippet

snippet tp "transpose" i
^(top)$0
endsnippet

snippet st "star" i
^(*)$0
endsnippet

snippet inv "inverse" i
^(-1)$0
endsnippet

snippet ort "orthogonal (perp)" i
^(perp)$0
endsnippet

snippet ttl "env title" i
(title: [$1])
endsnippet

